<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>龚仔的摄影日记</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <style>
    :root{--bg:#08080c;--card:#111116;--card-hover:#1a1a20;--text:#f5f5f7;--muted:#6b6b7a;--accent:#e07a5f;--accent-glow:rgba(224,122,95,0.15);--border:#1e1e26}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:'Inter','PingFang SC','Microsoft YaHei',sans-serif;line-height:1.7;min-height:100vh;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    ::selection{background:var(--accent);color:#fff}
    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:var(--card);border-radius:3px}
    ::-webkit-scrollbar-thumb:hover{background:var(--card-hover)}
    .site-header{padding:24px 48px;display:flex;justify-content:flex-start;align-items:center;position:fixed;top:0;left:0;right:0;z-index:100;background:linear-gradient(to bottom,var(--bg) 0%,var(--bg) 50%,transparent 100%);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}
    .site-header h1{font-size:1.2rem;font-weight:600;letter-spacing:-0.02em;display:flex;align-items:center;gap:12px}
    .site-header h1 a{transition:all .3s ease}
    .site-header h1 a:hover{opacity:.8}
    .logo-icon{width:32px;height:32px;background:linear-gradient(135deg,var(--accent) 0%,#f2a07b 100%);border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px var(--accent-glow);transition:transform .3s ease,box-shadow .3s ease}
    .logo-icon:hover{transform:scale(1.08);box-shadow:0 6px 30px var(--accent-glow)}
    .container{max-width:1400px;margin:0 auto;padding:140px 48px 80px;flex:1}
    .hero{text-align:center;padding:0 20px 80px}
    .hero h1{font-size:3.2rem;font-weight:700;letter-spacing:-0.04em;margin-bottom:16px;background:linear-gradient(135deg,var(--text) 0%,var(--muted) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero p{color:var(--muted);font-size:1.15rem;max-width:480px;margin:0 auto;letter-spacing:0.02em}
    .albums{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:28px}
    .album{background:var(--card);border-radius:20px;overflow:hidden;cursor:pointer;border:1px solid var(--border);transition:all .4s cubic-bezier(.25,.46,.45,.94);opacity:0;transform:translateY(20px);animation:fadeInUp .5s ease forwards}
    .album:hover{transform:translateY(-10px);box-shadow:0 30px 80px rgba(0,0,0,.5),0 0 0 1px var(--accent);border-color:var(--accent)}
    @keyframes fadeInUp{to{opacity:1;transform:translateY(0)}}
    .album:nth-child(1){animation-delay:.05s}
    .album:nth-child(2){animation-delay:.1s}
    .album:nth-child(3){animation-delay:.15s}
    .album:nth-child(4){animation-delay:.2s}
    .album:nth-child(5){animation-delay:.25s}
    .album:nth-child(6){animation-delay:.3s}
    .album:nth-child(7){animation-delay:.35s}
    .album:nth-child(8){animation-delay:.4s}
    .album:nth-child(9){animation-delay:.45s}
    .album:nth-child(10){animation-delay:.5s}
    .album:nth-child(11){animation-delay:.55s}
    .album:nth-child(12){animation-delay:.6s}
    .album-cover{aspect-ratio:16/11;overflow:hidden;position:relative}
    .album-cover img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.25,.46,.45,.94)}
    .album:hover .album-cover img{transform:scale(1.1)}
    .album-cover::after{content:'';position:absolute;bottom:0;left:0;right:0;height:50%;background:linear-gradient(to top,rgba(0,0,0,.5),transparent);pointer-events:none;opacity:0;transition:opacity .4s ease}
    .album:hover .album-cover::after{opacity:1}
    .album-info{padding:22px 26px;position:relative}
    .album-info::before{content:'';position:absolute;top:0;left:26px;right:26px;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);transition:background .4s ease}
    .album:hover .album-info::before{background:linear-gradient(90deg,transparent,var(--accent),transparent)}
    .album-date{font-size:1.2rem;font-weight:600;margin-bottom:6px;letter-spacing:-0.01em;transition:color .3s ease}
    .album:hover .album-date{color:var(--accent)}
    .album-count{color:var(--muted);font-size:.9rem;display:flex;align-items:center;gap:6px;transition:color .3s ease}
    .album:hover .album-count{color:var(--text)}
    .album-count svg{width:16px;height:16px;opacity:.6;transition:opacity .3s ease}
    .album:hover .album-count svg{opacity:1}
    .pagination{display:flex;justify-content:center;align-items:center;gap:10px;margin-top:80px;padding:30px;flex-wrap:wrap}
    .pagination button{min-width:48px;height:48px;background:var(--card);border:1px solid var(--border);color:var(--text);padding:0 18px;border-radius:12px;cursor:pointer;transition:all .3s cubic-bezier(.25,.46,.45,.94);font-size:.95rem;font-weight:500;display:flex;align-items:center;justify-content:center}
    .pagination button:hover:not(:disabled){background:var(--card-hover);border-color:var(--accent);color:var(--accent);transform:translateY(-3px);box-shadow:0 8px 25px rgba(224,122,95,.2)}
    .pagination button:disabled{opacity:.3;cursor:not-allowed;transform:none;box-shadow:none}
    .pagination .page-info{color:var(--text);font-size:.95rem;padding:0 16px;min-width:90px;text-align:center;font-weight:500}
    .site-footer{text-align:center;padding:50px;border-top:1px solid var(--border);color:var(--muted);font-size:.85rem;margin-top:auto}
    .site-footer a{color:var(--accent);transition:all .3s ease;position:relative}
    .site-footer a::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--accent);transform:scaleX(0);transition:transform .3s ease}
    .site-footer a:hover::after{transform:scaleX(1)}
    .loading{text-align:center;padding:120px 20px;color:var(--muted)}
    .loading-spinner{width:48px;height:48px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 20px}
    @keyframes spin{to{transform:rotate(360deg)}}
    .empty{text-align:center;padding:100px 20px;color:var(--muted)}
    .empty-icon{font-size:4rem;margin-bottom:16px;opacity:.5}
    @media(max-width:768px){
      .site-header{padding:16px 20px}
      .container{padding:120px 20px 60px}
      .hero{padding:0 0 60px}
      .hero h1{font-size:2.2rem}
      .albums{grid-template-columns:repeat(2,1fr);gap:16px}
      .album-info{padding:16px 18px}
      .album-date{font-size:1rem}
      .pagination{margin-top:50px;padding:20px}
    }
    @media(max-width:480px){
      .albums{grid-template-columns:1fr}
      .hero h1{font-size:1.8rem}
    }
  </style>
</head>
<body>
  <header class="site-header">
    <h1>
      <span class="logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5">
          <circle cx="12" cy="12" r="10"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="19" cy="8" r="2" fill="#fff" stroke="none"/>
        </svg>
      </span>
      <a href="/">龚仔的摄影日记</a>
    </h1>
  </header>
  <main class="container">
    <section class="hero">
      <h1>记录生活，定格美好</h1>
      <p>用镜头捕捉每一个值得珍藏的瞬间</p>
    </section>
    <div id="loadingState" class="loading">
      <div class="loading-spinner"></div>
      <p>正在加载相册...</p>
    </div>
    <div id="emptyState" class="empty" style="display:none">
      <div class="empty-icon">📭</div>
      <p>暂无相册</p>
    </div>
    <div class="albums" id="albumGrid" style="display:none"></div>
    <div class="pagination" id="pagination" style="display:none"></div>
  </main>
  <footer class="site-footer">
    <p>© 2026 龚仔的摄影日记 | <a href="https://v.douyin.com/Hc74k9FgjPY/" target="_blank">@龚仔仔仔仔</a></p>
  </footer>
  <script>
    const grid = document.getElementById('albumGrid');
    const pagination = document.getElementById('pagination');
    const loading = document.getElementById('loadingState');
    const emptyState = document.getElementById('emptyState');
    const PER_PAGE = 12;
    let currentPage = 1;
    let albums = [];
    let totalPages = 1;

    async function loadAlbums() {
      try {
        const apiBase = window.location.hostname === 'localhost' ? 'http://localhost:1023' : '';
        const response = await fetch(apiBase + '/.netlify/functions/albums');
        if (!response.ok) throw new Error('Failed to load');
        const data = await response.json();
        albums = data.albums || [];
        totalPages = Math.max(1, Math.ceil(albums.length / PER_PAGE));
        
        loading.style.display = 'none';
        if (albums.length === 0) {
          emptyState.style.display = 'block';
        } else {
          grid.style.display = 'grid';
          pagination.style.display = 'flex';
          renderPage(1);
        }
      } catch (error) {
        console.error('Load error:', error);
        loading.innerHTML = '<p>加载失败，请确保本地API服务器已启动<br><br>运行: <strong>npm run dev</strong></p>';
      }
    }

    function renderPage(page) {
      currentPage = page;
      grid.innerHTML = '';
      const start = (page - 1) * PER_PAGE;
      const end = Math.min(start + PER_PAGE, albums.length);

      for (let i = start; i < end; i++) {
        const album = albums[i];
        const coverUrl = album.coverImage || (album.images && album.images[0] && album.images[0].url) || '';
        const photoCount = album.images ? album.images.length : 0;
        
        const article = document.createElement('article');
        article.className = 'album';
        article.innerHTML = `
          <div class="album-cover">
            <img src="${coverUrl}" alt="${album.date}" loading="lazy">
          </div>
          <div class="album-info">
            <div class="album-date">${album.date}</div>
            <div class="album-count">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              ${photoCount} 张照片
            </div>
          </div>
        `;
        article.onclick = () => { window.location.href = album.url; };
        grid.appendChild(article);
      }

      renderPagination();
    }

    function renderPagination() {
      pagination.innerHTML = '';
      if (totalPages <= 1) return;

      const firstBtn = document.createElement('button');
      firstBtn.innerHTML = '&#x23EE;';
      firstBtn.title = '首页';
      firstBtn.disabled = currentPage === 1;
      firstBtn.onclick = () => { currentPage = 1; renderPage(1); window.scrollTo({top:0, behavior:'smooth'}); };

      const prevBtn = document.createElement('button');
      prevBtn.innerHTML = '&#x25C0;';
      prevBtn.title = '上一页';
      prevBtn.disabled = currentPage === 1;
      prevBtn.onclick = () => { currentPage--; renderPage(currentPage); window.scrollTo({top:0, behavior:'smooth'}); };

      const info = document.createElement('span');
      info.className = 'page-info';
      info.textContent = currentPage + ' / ' + totalPages;

      const nextBtn = document.createElement('button');
      nextBtn.innerHTML = '&#x25B6;';
      nextBtn.title = '下一页';
      nextBtn.disabled = currentPage === totalPages;
      nextBtn.onclick = () => { currentPage++; renderPage(currentPage); window.scrollTo({top:0, behavior:'smooth'}); };

      const lastBtn = document.createElement('button');
      lastBtn.innerHTML = '&#x23ED;';
      lastBtn.title = '末页';
      lastBtn.disabled = currentPage === totalPages;
      lastBtn.onclick = () => { currentPage = totalPages; renderPage(totalPages); window.scrollTo({top:0, behavior:'smooth'}); };

      pagination.appendChild(firstBtn);
      pagination.appendChild(prevBtn);
      pagination.appendChild(info);
      pagination.appendChild(nextBtn);
      pagination.appendChild(lastBtn);
    }

    loadAlbums();
  </script>
</body>
</html>
