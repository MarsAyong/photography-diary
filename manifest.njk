---
permalink: /manifest.json
---
{
  "name": "{{ site.siteName }}",
  "short_name": "{{ site.siteName }}",
  "description": "{{ site.siteDescription }}",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#08080c",
  "theme_color": "#e07a5f",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "categories": ["photo", "lifestyle"]
}
